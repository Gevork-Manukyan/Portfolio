# Copy to .env.local and fill in. .env.local is gitignored.

# Public site URL (used for metadata, OG tags, sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── Gmail SMTP (contact form) ──────────────────────────────────────────
# Gmail account that sends the emails.
GMAIL_USER=you@gmail.com

# 16-char Google App Password (requires 2-Step Verification).
# Generate at https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# Where contact-form submissions are delivered (defaults to GMAIL_USER).
CONTACT_TO_EMAIL=you@gmail.com
